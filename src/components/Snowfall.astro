---
// src/components/Snowfall.astro
// 这个组件只负责提供一个容器，实际的绘制逻辑在 script 里
const height = "100vh";
const width = "100%";
---
<div id="snowfall-container" style="position: fixed; top: 0; left: 0; width: {width}; height: {height}; pointer-events: none; z-index: 9999;">
</div>

<script>
 
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('snowfall-container');


    const canvas = document.createElement('canvas');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    canvas.style.display = 'block';
    container.appendChild(canvas);

    const ctx = canvas.getContext('2d');


    let flakes = [];
    const flakeCount = 150; // 雪花数量，可根据性能调整

    // 初始化雪花
    function initFlakes() {
      flakes = [];
      for (let i = 0; i < flakeCount; i++) {
        flakes.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          speed: Math.random() * 1 + 0.5,
          radius: Math.random() * 3 + 1,
          wind: Math.random() * 0.5 - 0.25,
        });
      }
    }

    // 绘制雪花
    function drawFlakes() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = 'white';
      ctx.shadowColor = 'rgba(255, 255, 255, 0.3)';
      ctx.shadowBlur = 5;
      ctx.beginPath();

      for (let flake of flakes) {
        ctx.moveTo(flake.x, flake.y);
        ctx.arc(flake.x, flake.y, flake.radius, 0, Math.PI * 2);
      }
      ctx.fill();
    }

    // 更新雪花位置
    function updateFlakes() {
      for (let flake of flakes) {
        flake.y += flake.speed;
        flake.x += flake.wind;

        // 让雪花从顶部重新出现
        if (flake.y > canvas.height) {
          flake.y = -flake.radius;
          flake.x = Math.random() * canvas.width;
        }
        // 左右边缘循环
        if (flake.x > canvas.width) {
          flake.x = -flake.radius;
        } else if (flake.x < -flake.radius) {
          flake.x = canvas.width;
        }
      }
    }

    // 动画循环
    function animate() {
      updateFlakes();
      drawFlakes();
      requestAnimationFrame(animate);
    }

    // 窗口大小变化时重新调整 canvas 尺寸
    function handleResize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      initFlakes(); // 重置雪花位置以适应新尺寸
    }

    // 启动动画
    initFlakes();
    animate();

    // 监听窗口尺寸变化
    window.addEventListener('resize', handleResize);
  });
</script>

<style>
  /* 确保组件不会遮挡点击事件 */
  #snowfall-container {
    pointer-events: none;
  }
</style>