---
import fs from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

interface Props {
  dir?: string;            
  showSize?: boolean;      
  showTrack?: boolean;     
}

const { 
  dir = 'downloads', 
  showSize = true, 
  showTrack = true 
} = Astro.props;

interface FileNode {
  name: string;
  type: 'file' | 'directory';
  relativePath: string;
  downloadPath: string;  
  bytes: number;         
  timeString: string;    
  timestamp: number;     
  sizeString: string;    
  children?: FileNode[];
}

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const projectRoot = path.resolve(__dirname, '../..');
const TARGET_DIR = path.join(projectRoot, '', dir);

const fallbackTargetDir = path.join(projectRoot, '', dir);
const actualTargetDir = fs.existsSync(TARGET_DIR) ? TARGET_DIR : fallbackTargetDir;

if (import.meta.env.DEV) {
  console.log('[DownloadManager]', {
    projectRoot,
    TARGET_DIR,
    targetDirExists: fs.existsSync(TARGET_DIR),
    fallbackTargetDir,
    actualTargetDir,
    actualDirExists: fs.existsSync(actualTargetDir),
  });
}

function formatBytes(bytes: number, decimals = 2) {
  if (bytes === 0) return '0 Bytes';
  const k = 1024;
  const dm = decimals < 0 ? 0 : decimals;
  const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB'];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
}

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit',
  });
}

function readDirectory(dirPath: string, relativePath = ''): FileNode[] {
  if (!fs.existsSync(dirPath)) return [];

  const files = fs.readdirSync(dirPath);
  const nodes: FileNode[] = [];

  for (const file of files) {
    if (file.startsWith('.')) continue;

    const fullPath = path.join(dirPath, file);
    const stat = fs.statSync(fullPath);
    const currentRelativePath = path.join(relativePath, file).replace(/\\/g, '/');

    if (stat.isDirectory()) {
      const currentDownloadPath = `/${dir}/${currentRelativePath}`;
      nodes.push({
        name: file,
        type: 'directory',
        relativePath: currentRelativePath,
        downloadPath: currentDownloadPath,
        bytes: 0,
        timestamp: stat.mtime.getTime(),
        timeString: formatDate(stat.mtime),
        sizeString: '',
        children: readDirectory(fullPath, currentRelativePath)
      });
    } else {
      const currentDownloadPath = `/${dir}/${currentRelativePath}`;
      nodes.push({
        name: file,
        type: 'file',
        relativePath: currentRelativePath,
        downloadPath: currentDownloadPath,
        bytes: stat.size,
        timestamp: stat.mtime.getTime(),
        timeString: formatDate(stat.mtime),
        sizeString: formatBytes(stat.size)
      });
    }
  }

  return nodes.sort((a, b) => {
    if (a.type === b.type) return a.name.localeCompare(b.name);
    return a.type === 'directory' ? -1 : 1;
  });
}

function buildTreeHtml(nodes: FileNode[]): string {
  if (!nodes || nodes.length === 0) return '';
  
  let html = '';
  for (const node of nodes) {
    if (node.type === 'directory') {
      html += `
        <li class="my-1 list-none tree-node-dir" data-name="${node.name}" data-time="${node.timestamp}">
          <details open class="group">
            <summary class="flex items-center gap-2 font-medium text-zinc-700 dark:text-zinc-300 cursor-pointer hover:text-[var(--primary)] transition p-1.5 rounded-lg hover:bg-zinc-100/50 dark:hover:bg-zinc-800/30 list-none select-none">
              <span class="text-[10px] transition-transform group-open:rotate-90 text-zinc-400 group-hover:text-[var(--primary)]">▶</span>
              <span class="text-sm font-semibold">📁 ${node.name}</span>
            </summary>
            <ul class="file-tree-sub pl-4 border-l border-dashed border-zinc-200 dark:border-zinc-800 mt-1 space-y-1 ml-2 p-0">
              ${buildTreeHtml(node.children || [])}
            </ul>
          </details>
        </li>
      `;
    } else {
      html += `
        <li class="tree-node-file flex flex-col sm:flex-row sm:items-center justify-between p-2 rounded-lg hover:bg-zinc-100/50 dark:hover:bg-zinc-800/30 transition group gap-2 list-none" 
            data-name="${node.name}" data-size="${node.bytes}" data-time="${node.timestamp}">
          <div class="flex items-center gap-2 min-w-0">
            <span class="text-zinc-600 dark:text-zinc-400 text-sm truncate">📄 ${node.name}</span>
          </div>
          <div class="flex items-center justify-between sm:justify-end gap-4 text-[11px] text-zinc-400 dark:text-zinc-500 shrink-0">
            ${showSize ? `<span class="bg-zinc-200/60 dark:bg-zinc-800/60 px-1.5 py-0.5 rounded text-zinc-500 dark:text-zinc-400 font-mono">${node.sizeString}</span>` : ''}
            ${showTrack ? `<span>更新时间: ${node.timeString}</span>` : ''}
            <button class="download-btn opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition text-[11px] bg-[var(--primary)] text-white px-2.5 py-0.5 rounded shadow-sm font-medium hover:brightness-110" data-url="${node.downloadPath}" data-filename="${node.name}">下载</button>
          </div>
        </li>
      `;
    }
  }
  return html;
}

const fileTree = readDirectory(actualTargetDir);
const hasFiles = fileTree.length > 0;

let finalBodyHtml = '';
if (!hasFiles) {
  finalBodyHtml = `<p class="text-zinc-400 text-center py-6 text-sm">暂无可用下载文件，请放入 public/${dir}/ 目录</p>`;
} else {
  finalBodyHtml = `<ul class="file-tree-root space-y-1 m-0 p-0">${buildTreeHtml(fileTree)}</ul>`;
}
---

<div class="download-manager-wrapper w-full mt-6">
  <div class="flex flex-wrap items-center justify-between gap-4 mb-4 px-1" style={hasFiles ? "" : "display: none;"}>
    <div class="text-sm font-bold text-zinc-700 dark:text-zinc-300 flex items-center gap-1.5">
      📂 资源下载列表 ({dir})
    </div>
    <div class="flex items-center gap-2 text-xs text-zinc-500">
      <span>排序：</span>
      <select class="sort-selector bg-zinc-100 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded px-2 py-1 outline-none text-zinc-700 dark:text-zinc-300 cursor-pointer">
        <option value="name-asc">名字 (A-Z)</option>
        <option value="name-desc">名字 (Z-A)</option>
        <option value="size-desc" style={showSize ? "" : "display: none;"}>大小 (从大到小)</option>
        <option value="size-asc" style={showSize ? "" : "display: none;"}>大小 (从小到大)</option>
        <option value="time-desc" style={showTrack ? "" : "display: none;"}>时间 (最新优先)</option>
        <option value="time-asc" style={showTrack ? "" : "display: none;"}>时间 (最早优先)</option>
      </select>
    </div>
  </div>

  <div class="bg-zinc-50/50 dark:bg-zinc-950/30 border border-black/5 dark:border-white/5 rounded-xl p-4 shadow-inner" set:html={finalBodyHtml}>
  </div>
</div>

<style is:inline>
  summary::-webkit-details-marker { display: none !important; }
  summary { display: flex !important; list-style: none !important; }
</style>

<script>
  const initializedWrappers = new Set<HTMLElement>();

  function handleDownloadClick(e: Event) {
    const target = e.target as HTMLElement;
    if (!target.classList.contains('download-btn')) return;
    
    const btn = target as HTMLButtonElement;
    const url = btn.getAttribute('data-url');
    const filename = btn.getAttribute('data-filename');
    if (!url || !filename) return;
    //这里感谢黑客Copilot。，
    (async () => {
      try {
        const response = await fetch(url);
        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
        
        const contentDisposition = response.headers.get('content-disposition');
        let downloadName = filename;
        if (contentDisposition && contentDisposition.includes('filename')) {
          const matches = contentDisposition.match(/filename\*?=(?:UTF-8'')?([^;]+)/);
          if (matches && matches[1]) {
            downloadName = decodeURIComponent(matches[1]);
          }
        }
        
        const blob = await response.blob();
        const blobUrl = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = blobUrl;
        a.download = downloadName;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(blobUrl);
      } catch (error) {
        console.error('Download failed:', error);
        alert('下载失败，可能是后缀的原因吧,我还不知道怎么改');
      }
    })();
  }

  function setupDownloadSort() {
    const wrappers = document.querySelectorAll('.download-manager-wrapper');
    
    wrappers.forEach(wrapper => {
      if (initializedWrappers.has(wrapper)) return;
      initializedWrappers.add(wrapper);
      
      wrapper.addEventListener('click', handleDownloadClick);
      
      const selector = wrapper.querySelector('.sort-selector') as HTMLSelectElement | null;
      if (!selector) return;

      selector.addEventListener('change', (e) => {
        const target = e.target as HTMLSelectElement | null;
        if (!target) return;
        
        const value = target.value;
        const [field, order] = value.split('-');

        const sortList = (ul: HTMLUListElement) => {
          const items = Array.from(ul.children) as HTMLElement[];
          
          items.sort((a, b) => {
            const isDirA = a.classList.contains('tree-node-dir');
            const isDirB = b.classList.contains('tree-node-dir');
            
            if (isDirA !== isDirB) return isDirA ? -1 : 1; 

            if (field === 'name') {
              const nameA = a.getAttribute('data-name') || '';
              const nameB = b.getAttribute('data-name') || '';
              return order === 'asc' ? nameA.localeCompare(nameB) : nameB.localeCompare(nameA);
            } 
            if (field === 'size') {
              const sizeA = parseInt(a.getAttribute('data-size') || '0', 10);
              const sizeB = parseInt(b.getAttribute('data-size') || '0', 10);
              return order === 'asc' ? sizeA - sizeB : sizeB - sizeA;
            }
            if (field === 'time') {
              const timeA = parseInt(a.getAttribute('data-time') || '0', 10);
              const timeB = parseInt(b.getAttribute('data-time') || '0', 10);
              return order === 'asc' ? timeA - timeB : timeB - timeA;
            }
            return 0;
          });

          items.forEach(item => ul.appendChild(item));
          ul.querySelectorAll('.file-tree-sub').forEach(subList => sortList(subList as HTMLUListElement)); 
        };

        const rootUl = wrapper.querySelector('.file-tree-root') as HTMLUListElement | null;
        if (rootUl) sortList(rootUl);
      });
    });
  }

  setupDownloadSort();
  document.addEventListener('astro:page-load', setupDownloadSort);
</script>